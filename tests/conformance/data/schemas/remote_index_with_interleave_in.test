@Dialect=GOOGLE_STANDARD_SQL
CREATE TABLE ParentTable (
  name STRING(MAX),
  age INT64
) PRIMARY KEY (name);
CREATE TABLE TestTable (
  name STRING(MAX),
  testname STRING(MAX),
  info STRING(MAX)
) PRIMARY KEY (name), INTERLEAVE IN ParentTable;
CREATE INDEX RemoteIndex ON TestTable(testname) STORING(info), INTERLEAVE IN ParentTable;
